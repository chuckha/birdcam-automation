# Required
OAUTH_CLIENT_SECRET_FILE=/path/to/client_secret.json
OAUTH_TOKEN_FILE=/path/to/oauth_token.json

# Optional (defaults shown)
DATA_DIR=/data
PYTHON_PATH=python3
HIGHLIGHTS_SCRIPT=detect_birds.py
YTDLP_PATH=yt-dlp

# Required for stream-manager only
LATITUDE=0.0
LONGITUDE=0.0
YOUTUBE_STREAM_KEY=xxxx-xxxx-xxxx-xxxx
TIMEZONE=UTC
